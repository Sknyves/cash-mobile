{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/cash.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"cash.apk\""
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ]
}
